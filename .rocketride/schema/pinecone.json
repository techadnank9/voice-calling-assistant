{
  "actions": 0,
  "capabilities": 2048,
  "classType": [
    "store"
  ],
  "description": "A component that connects to the Pinecone vector database for storing and retrieving \nhigh-dimensional embeddings. It enables efficient similarity search, indexing, and \nmanagement of vectorized data, such as text or image embeddings. Configurable with \nAPI credentials, index settings, and metadata filtering, the component supports fast \nand scalable operations across large embedding datasets. Ideal for semantic search, \nrecommendation systems, and retrieval-augmented generation workflows.",
  "documentation": "https://bit.ly/4hH28Jw",
  "icon": "pinecone.svg",
  "input": [
    {
      "description": "Stores the documents into the vector database. The documents must be \nrun through an embedding model prior to this step to compute the vectors.",
      "lane": "documents",
      "output": []
    },
    {
      "description": "Searchs the database for documents most similar to the given questions.",
      "lane": "questions",
      "output": [
        {
          "description": "Produces documents that are most similar to the given question.",
          "lane": "documents",
          "output": []
        },
        {
          "description": "Produces an answer with the documents that are most similar \nto the given question.",
          "lane": "answers",
          "output": []
        },
        {
          "description": "Updates the question with documents most similar to the \nquestion and sets up a filter so piping this to another store \ndriver will limit its answers to the given subset of documents.",
          "lane": "questions",
          "output": []
        }
      ]
    }
  ],
  "lanes": {
    "documents": [],
    "questions": [
      "documents",
      "answers",
      "questions"
    ]
  },
