      },
      "host": {},
      "score": {
        "ui:enumNames": [
          "All results",
          "Likely not related",
          "Possibly related",
          "Related",
          "Strongly related",
          "Highly relevant",
          "Almost identical"
        ]
      },
      "ui:order": [
        "host",
        "apikey",
        "score",
        "database",
        "collection"
      ]
    }
  },
