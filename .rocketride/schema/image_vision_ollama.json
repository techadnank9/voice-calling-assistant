  "description": "A component that connects to locally-hosted open-source vision models through Ollama \nfor image analysis, description, and visual understanding tasks. Supports Llama 3.2 Vision, \nLLaVA, Moondream, MiniCPM-V, and other multimodal models. Runs entirely on-premise with no \nexternal API keys required — ideal for privacy-sensitive applications.",
  "documentation": "https://bit.ly/3JFO3zk",
  "icon": "ollama.svg",
  "input": [
    {
      "description": "Image to analyze with a local Ollama vision model",
      "lane": "image",
      "output": [
        {
          "description": "Text analysis of the image content",
          "lane": "text"
        }
      ]
    },
    {
      "description": "Image documents to analyze with a local Ollama vision model",
      "lane": "documents",
      "output": [
        {
          "description": "Text analysis of each image document with original metadata (frame number, timestamp) preserved",
          "lane": "documents"
        }
      ]
    }
  ],
  "lanes": {
