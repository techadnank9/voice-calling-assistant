          "type": "array"
        },
        "include": {
          "description": "This path defines the paths included for Scan, Index, Classify and OCR. By default, its empty.\n\nFormat for Windows : C:\\foldername (for local filesystem) or \\\\file.core.net\\foldername (for shared folders)\n\nFormat for Linux : /file.core.net/foldername",
          "items": {
            "dependencies": {
              "index": {
                "oneOf": [
                  {
                    "properties": {
                      "classify": {
                        "default": false,
                        "description": "Classification will assign each file to one or more classification policies. Once enabled, all supported files will be classified into one or more of the activated classification policies.",
                        "title": "Enable Classification",
                        "type": "boolean"
                      },
                      "index": {
                        "enum": [
                          true
                        ]
                      },
                      "ocr": {
                        "default": false,
                        "description": "Optical Character Recognition (OCR) will convert typed or handwritten text found in images into text.Once enabled, all image files such as jpgs will have text extracted for use in classification and search.",
                        "title": "Enable OCR",
                        "type": "boolean"
                      }
                    }
                  },
                  {
                    "properties": {
                      "index": {
                        "enum": [
                          false
                        ]
                      }
                    }
                  }
                ]
              },
              "signing": {
                "oneOf": [
                  {
                    "properties": {
                      "index": {
                        "default": false,
                        "description": "Indexing will allow for full-text search of all processed files. Once enabled, all supported files will be scanned and indexed as they are processed.\nOnce Index is enabled, other parameters like OCR and classify could be enabled too.",
                        "title": "Enable Indexing",
                        "type": "boolean"
                      },
                      "signing": {
                        "enum": [
                          true
                        ]
                      },
                      "vectorize": {
                        "default": false,
                        "description": "AI embeddings make text content accessible to AI technologies like semantic relevancy and generative AP chants.\nOnce AI embeddings are enabled, other parameters like OCR and classify could be enabled too.",
                        "title": "Enable AI Embeddings",
                        "type": "boolean"
                      }
                    }
